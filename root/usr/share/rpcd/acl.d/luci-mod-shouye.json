{
  "luci-mod-shouye": {
    "description": "Grant access to shouye module",
    "read": {
      "ubus": {
        "system": [ "board", "info" ],
        "luci-rpc": [ "getDHCPLeases" ],
        "network": [ "get_wifi_devices", "get_wifi_networks", "get_host_hints" ]
      },
      "uci": [ "system" ],
      "file": [ "/sys/class/thermal/thermal_zone0/temp" ]
    }
  }
}